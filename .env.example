# Copy to .env for deployment. Never commit the real .env file.
BASE_DOMAIN=barbaraplascencia.com
LANDING_URL=https://fraud.barbaraplascencia.com
APP_PUBLIC_URL=https://app.barbaraplascencia.com
API_PUBLIC_URL=https://api.barbaraplascencia.com
MLFLOW_PUBLIC_URL=https://mlflow.barbaraplascencia.com
H2O_PUBLIC_URL=https://h2o.barbaraplascencia.com
GITHUB_URL=https://github.com/AIQwerty-practice/AIDev_CC_Fraud_MLOPS

# Docker-internal service URLs. Do not replace these with public HTTPS URLs.
INTERNAL_API_URL=http://backend:8000
INTERNAL_MLFLOW_TRACKING_URI=http://mlflow:5000
INTERNAL_H2O_URL=http://h2o:54321

ALLOWED_ORIGINS=https://fraud.barbaraplascencia.com,https://app.barbaraplascencia.com
MLFLOW_SERVER_ALLOWED_HOSTS=mlflow,localhost,127.0.0.1,backend,trainer,mlflow.barbaraplascencia.com

MODEL_NAME=fraud-detection-automl
MODEL_ALIAS=champion
MODEL_ARTIFACT_DIR=/app/model_artifacts
CERTBOT_EMAIL=replace-with-your-email@example.com

# Keep internal services bound to EC2 loopback; only Nginx publishes 80/443.
H2O_BIND_ADDRESS=127.0.0.1
MLFLOW_BIND_ADDRESS=127.0.0.1
API_BIND_ADDRESS=127.0.0.1
APP_BIND_ADDRESS=127.0.0.1
